"""Portable OHLCV fetch — generated by Stockya-tuner.

Generated:  2026-06-21_2146
Symbol:     STLTECH.NS
Range:      2025-06-01 .. 2026-06-30

Run on a machine with internet + Python 3.10+:
    pip install yfinance pandas
    python "C:/Claude_projects/Stockya-tuner/requests/fetch_2026-06-21_2146_STLTECH.NS.py"

The script writes the result CSV next to itself as:
    STLTECH.NS.csv

Then copy that CSV back to the tuner machine at:
    C:/Claude_projects/Stockya-tuner/data/ohlcv/STLTECH.NS.csv
"""
from __future__ import annotations
import sys
from pathlib import Path

try:
    import yfinance as yf
    import pandas as pd
except ImportError as e:
    print(f"missing dependency: {e}. Run: pip install yfinance pandas")
    sys.exit(1)

SYMBOL = "STLTECH.NS"
START = "2025-06-01"
END = "2026-06-30"
OUT = Path(__file__).resolve().parent / (SYMBOL + ".csv")

print(f"Fetching {SYMBOL} from {START} to {END} ...")
df = yf.download(SYMBOL, start=START, end=END, auto_adjust=False, progress=False)
if df.empty:
    print(f"No data for {SYMBOL} between {START} and {END}")
    sys.exit(2)

# yfinance sometimes returns MultiIndex columns; flatten to a single level.
if hasattr(df.columns, "levels"):
    df.columns = [c[0] if isinstance(c, tuple) else c for c in df.columns]

df = df[["Open", "High", "Low", "Close", "Volume"]].dropna()
df.index = pd.to_datetime(df.index).tz_localize(None).normalize()
df.index.name = "Date"
df["Volume"] = df["Volume"].astype("int64")
df.to_csv(OUT, date_format="%Y-%m-%d")

print(f"Wrote {OUT} ({len(df)} rows)")
print("Now copy this file to the tuner machine at:")
print(r"    C:/Claude_projects/Stockya-tuner/data/ohlcv/STLTECH.NS.csv")
