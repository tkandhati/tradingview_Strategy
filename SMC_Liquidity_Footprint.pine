// ============================================================
// SMC Liquidity Volume Footprint — Smart Money Concept
// Timeframe: 15 Minutes (works on any TF)
// Includes: Order Blocks, FVG, Swing S/R, BOS/CHOCH, Volume Nodes
// ============================================================
//@version=5
indicator("SMC Liquidity Footprint [15m]", overlay=true, max_boxes_count=200, max_lines_count=200, max_labels_count=200)

// ─────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────
grp1 = "Order Blocks"
ob_lookback     = input.int(10,  "OB Lookback Candles",    group=grp1, minval=3, maxval=50)
ob_show         = input.bool(true, "Show Order Blocks",    group=grp1)

grp2 = "Fair Value Gaps"
fvg_show        = input.bool(true, "Show Fair Value Gaps", group=grp2)
fvg_min_size    = input.float(0.0, "Min FVG Size (0 = any)", group=grp2, minval=0.0)

grp3 = "Swing Liquidity"
swing_length    = input.int(10, "Swing Lookback",          group=grp3, minval=3, maxval=50)
swing_show      = input.bool(true, "Show Swing S/R Lines", group=grp3)
max_swings      = input.int(5, "Max Levels to Show",       group=grp3, minval=1, maxval=10)

grp4 = "BOS / CHOCH"
bos_show        = input.bool(true, "Show BOS Labels",      group=grp4)
choch_show      = input.bool(true, "Show CHOCH Labels",    group=grp4)

grp5 = "Volume Nodes"
vol_show        = input.bool(true, "Show Volume Nodes",    group=grp5)
vol_lookback    = input.int(50,  "Volume Lookback",        group=grp5, minval=10, maxval=200)
vol_threshold   = input.float(1.5, "HVN Multiplier (x avg)", group=grp5, minval=1.0)

grp6 = "Colors"
col_bull_ob     = input.color(color.new(color.green,  75), "Bullish OB",    group=grp6)
col_bear_ob     = input.color(color.new(color.red,    75), "Bearish OB",    group=grp6)
col_bull_fvg    = input.color(color.new(color.aqua,   80), "Bullish FVG",   group=grp6)
col_bear_fvg    = input.color(color.new(color.orange, 80), "Bearish FVG",   group=grp6)
col_swing_hi    = input.color(color.new(color.red,    20), "Swing High",    group=grp6)
col_swing_lo    = input.color(color.new(color.green,  20), "Swing Low",     group=grp6)
col_hvn         = input.color(color.new(color.yellow, 60), "High Vol Node", group=grp6)

// ─────────────────────────────────────────
// HELPERS
// ─────────────────────────────────────────
is_swing_high(len) =>
    result = true
    for i = 1 to len
        if high[i] > high[0]
            result := false
    result

is_swing_low(len) =>
    result = true
    for i = 1 to len
        if low[i] < low[0]
            result := false
    result

bullish_impulse(lookback) =>
    math.abs(close - open) >= ta.atr(14) * 0.5 and close > open and close > high[lookback]

bearish_impulse(lookback) =>
    math.abs(close - open) >= ta.atr(14) * 0.5 and close < open and close < low[lookback]

// ─────────────────────────────────────────
// 1. ORDER BLOCKS
// ─────────────────────────────────────────
var box bull_ob_box = na
var box bear_ob_box = na

if ob_show
    // Bullish OB: last bearish candle before a bullish impulse
    if bullish_impulse(ob_lookback)
        ob_bar = 1
        for i = 1 to ob_lookback
            if close[i] < open[i]
                ob_bar := i
                break
        box.new(
             left   = bar_index[ob_bar + 1],
             top    = open[ob_bar],
             right  = bar_index,
             bottom = close[ob_bar],
             bgcolor= col_bull_ob,
             border_color = color.green,
             border_width = 1
             )

    // Bearish OB: last bullish candle before a bearish impulse
    if bearish_impulse(ob_lookback)
        ob_bar = 1
        for i = 1 to ob_lookback
            if close[i] > open[i]
                ob_bar := i
                break
        box.new(
             left   = bar_index[ob_bar + 1],
             top    = close[ob_bar],
             right  = bar_index,
             bottom = open[ob_bar],
             bgcolor= col_bear_ob,
             border_color = color.red,
             border_width = 1
             )

// ─────────────────────────────────────────
// 2. FAIR VALUE GAPS (FVG)
// ─────────────────────────────────────────
if fvg_show
    // Bullish FVG: gap between candle[2] high and current candle low
    bull_fvg_top    = low[0]
    bull_fvg_bottom = high[2]
    if bull_fvg_top > bull_fvg_bottom and close[1] > open[1]
        gap_size = bull_fvg_top - bull_fvg_bottom
        if gap_size >= fvg_min_size
            box.new(
                 left   = bar_index[2],
                 top    = bull_fvg_top,
                 right  = bar_index + 20,
                 bottom = bull_fvg_bottom,
                 bgcolor= col_bull_fvg,
                 border_color = color.new(color.aqua, 50),
                 border_width = 1
                 )

    // Bearish FVG: gap between candle[2] low and current candle high
    bear_fvg_top    = low[2]
    bear_fvg_bottom = high[0]
    if bear_fvg_top > bear_fvg_bottom and close[1] < open[1]
        gap_size2 = bear_fvg_top - bear_fvg_bottom
        if gap_size2 >= fvg_min_size
            box.new(
                 left   = bar_index[2],
                 top    = bear_fvg_top,
                 right  = bar_index + 20,
                 bottom = bear_fvg_bottom,
                 bgcolor= col_bear_fvg,
                 border_color = color.new(color.orange, 50),
                 border_width = 1
                 )

// ─────────────────────────────────────────
// 3. SWING HIGH / LOW — LIQUIDITY LEVELS
// ─────────────────────────────────────────
var swing_hi_count = 0
var swing_lo_count = 0

if swing_show
    if is_swing_high(swing_length) and swing_hi_count < max_swings
        line.new(
             x1     = bar_index[swing_length],
             y1     = high[swing_length],
             x2     = bar_index + 30,
             y2     = high[swing_length],
             color  = col_swing_hi,
             width  = 1,
             style  = line.style_dashed
             )
        label.new(
             x      = bar_index[swing_length],
             y      = high[swing_length],
             text   = "Resistance\n" + str.tostring(high[swing_length], "#.####"),
             color  = color.new(color.red, 70),
             textcolor = color.white,
             style  = label.style_label_right,
             size   = size.small
             )
        swing_hi_count += 1

    if is_swing_low(swing_length) and swing_lo_count < max_swings
        line.new(
             x1     = bar_index[swing_length],
             y1     = low[swing_length],
             x2     = bar_index + 30,
             y2     = low[swing_length],
             color  = col_swing_lo,
             width  = 1,
             style  = line.style_dashed
             )
        label.new(
             x      = bar_index[swing_length],
             y      = low[swing_length],
             text   = "Support\n" + str.tostring(low[swing_length], "#.####"),
             color  = color.new(color.green, 70),
             textcolor = color.white,
             style  = label.style_label_right,
             size   = size.small
             )
        swing_lo_count += 1

// ─────────────────────────────────────────
// 4. BREAK OF STRUCTURE (BOS) & CHOCH
// ─────────────────────────────────────────
swing_hi_val = ta.pivothigh(high, swing_length, swing_length)
swing_lo_val = ta.pivotlow(low,  swing_length, swing_length)

var float last_swing_hi = na
var float last_swing_lo = na
var bool  trend_up      = true

if not na(swing_hi_val)
    last_swing_hi := swing_hi_val
if not na(swing_lo_val)
    last_swing_lo := swing_lo_val

// BOS — bullish: price closes above last swing high
if bos_show and not na(last_swing_hi) and close > last_swing_hi and close[1] <= last_swing_hi
    if trend_up
        label.new(bar_index, high, "BOS ▲", color=color.new(color.green,40), textcolor=color.white, style=label.style_label_down, size=size.small)
    trend_up := true

// BOS — bearish: price closes below last swing low
if bos_show and not na(last_swing_lo) and close < last_swing_lo and close[1] >= last_swing_lo
    if not trend_up
        label.new(bar_index, low, "BOS ▼", color=color.new(color.red,40), textcolor=color.white, style=label.style_label_up, size=size.small)
    trend_up := false

// CHOCH — reversal signal
if choch_show and not na(last_swing_hi) and not na(last_swing_lo)
    if trend_up and close < last_swing_lo and close[1] >= last_swing_lo
        label.new(bar_index, low, "CHOCH ↓", color=color.new(color.orange,30), textcolor=color.white, style=label.style_label_up, size=size.small)
        trend_up := false
    if not trend_up and close > last_swing_hi and close[1] <= last_swing_hi
        label.new(bar_index, high, "CHOCH ↑", color=color.new(color.blue,30), textcolor=color.white, style=label.style_label_down, size=size.small)
        trend_up := true

// ─────────────────────────────────────────
// 5. VOLUME NODES (High Volume S/R)
// ─────────────────────────────────────────
if vol_show
    avg_vol = ta.sma(volume, vol_lookback)
    is_hvn  = volume > avg_vol * vol_threshold

    if is_hvn
        hvn_price = (high + low) / 2
        line.new(
             x1    = bar_index - 3,
             y1    = hvn_price,
             x2    = bar_index + 25,
             y2    = hvn_price,
             color = col_hvn,
             width = 2,
             style = line.style_dotted
             )
        label.new(
             x         = bar_index,
             y         = hvn_price,
             text      = "HVN",
             color     = color.new(color.yellow, 60),
             textcolor = color.black,
             style     = label.style_label_left,
             size      = size.tiny
             )

// ─────────────────────────────────────────
// 6. BACKGROUND TREND BIAS
// ─────────────────────────────────────────
bgcolor(trend_up ? color.new(color.green, 97) : color.new(color.red, 97), title="Trend Bias Background")

// ─────────────────────────────────────────
// 7. ALERTS
// ─────────────────────────────────────────
alertcondition(bullish_impulse(ob_lookback), title="Bullish Order Block Formed",  message="SMC: Bullish Order Block detected — potential Support zone")
alertcondition(bearish_impulse(ob_lookback), title="Bearish Order Block Formed",  message="SMC: Bearish Order Block detected — potential Resistance zone")
alertcondition(not na(last_swing_hi) and close > last_swing_hi and close[1] <= last_swing_hi, title="BOS Bullish", message="SMC: Break of Structure — Bullish BOS confirmed")
alertcondition(not na(last_swing_lo) and close < last_swing_lo and close[1] >= last_swing_lo, title="BOS Bearish", message="SMC: Break of Structure — Bearish BOS confirmed")
